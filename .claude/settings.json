{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read(**)", "Glob(**)", "Grep(**)",
      "Bash(flutter *)",
      "Bash(dart *)",
      "Bash(adb *)",
      "Bash(cd android && ./gradlew *)"
    ],
    "deny": [
      "Read(**/*.keystore)",
      "Read(**/key.properties)",
      "Read(./.env*)",
      "Bash(rm -rf *)",
      "Bash(git push --force*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "dart format lib >/dev/null 2>&1 || true" }
        ]
      }
    ]
  }
}